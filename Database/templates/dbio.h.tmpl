// Bridges the {name} table (CRUDL) and the JSON/XML adapters: bulk
// export/import of the whole table (spec stage 9/10, the database-backed
// functions deferred until the database layer existed).
namespace harpia {{
namespace dbio {{

// export every row as newline-delimited JSON (one {name} per line)
inline bool export_json(::harpia::db::{name}_dao& dao, std::string* out) {{
    std::vector<::{name}> rows;
    if (!dao.list(&rows)) return false;
    out->clear();
    for (const auto& r : rows) {{
        std::string j;
        if (!::harpia::json::to_json(r, &j)) return false;
        *out += j;
        *out += "\n";
    }}
    return true;
}}

// import newline-delimited JSON into the table (one {name} per line)
inline bool import_json(::harpia::db::{name}_dao& dao, const std::string& ndjson) {{
    std::istringstream ss(ndjson);
    std::string line;
    while (std::getline(ss, line)) {{
        if (line.empty()) continue;
        ::{name} msg;
        if (!::harpia::json::from_json(line, &msg)) return false;
        if (!dao.create(msg)) return false;
    }}
    return true;
}}

// export every row as <{name}_list> ... </{name}_list>
inline bool export_xml(::harpia::db::{name}_dao& dao, std::string* out) {{
    std::vector<::{name}> rows;
    if (!dao.list(&rows)) return false;
    *out = "<{name}_list>";
    for (const auto& r : rows) *out += ::harpia::xml::to_xml(r);
    *out += "</{name}_list>";
    return true;
}}

// import <{name}_list> ... </{name}_list> into the table
inline bool import_xml(::harpia::db::{name}_dao& dao, const std::string& xml) {{
    ::tinyxml2::XMLDocument doc;
    if (doc.Parse(xml.c_str()) != ::tinyxml2::XML_SUCCESS) return false;
    const auto* root = doc.RootElement();
    if (!root) return false;
    for (const auto* el = root->FirstChildElement(); el;
         el = el->NextSiblingElement()) {{
        ::{name} msg;
        if (!::harpia::xml::from_xml_element(el, &msg)) return false;
        if (!dao.create(msg)) return false;
    }}
    return true;
}}

